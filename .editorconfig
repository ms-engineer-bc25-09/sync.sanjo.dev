# sync-sanjo/.editorconfig
# =========================================
# EditorConfig
# 役割:
# - Mac / Windows の改行コード差分を防ぐ
# - インデントルールを統一する
# - Gitの不要な差分を減らす
# =========================================

# このファイルがプロジェクトのルート
root = true

# =========================================
# 全ファイル共通設定
# =========================================
[*]

# 文字コード
charset = utf-8

# 改行コード
# lf = Linux / Mac 共通
# WindowsでもGitが自動変換するので問題なし
end_of_line = lf

# ファイル末尾の空行
insert_final_newline = true

# 行末の空白削除
trim_trailing_whitespace = true

# =========================================
# JavaScript / TypeScript
# =========================================
[*.{js,ts,jsx,tsx}]

indent_style = space
indent_size = 2

# =========================================
# JSON / YAML
# =========================================
[*.{json,yml,yaml}]

indent_style = space
indent_size = 2

# =========================================
# Markdown
# =========================================
[*.md]

# Markdownは行末スペースが意味を持つ場合があるので削除しない
trim_trailing_whitespace = false