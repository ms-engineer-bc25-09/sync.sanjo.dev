# sync-sanjo/.env.example
# =============================================================
# Sync Sanjo 環境変数設定ファイル（見本）
# =============================================================
# 使い方
# 1. このファイルをコピーして .env を作る
# 2. 各自の値を入れる
# 3. .env は Git に push しない
#
# Mac / Linux:
# cp .env.example .env
#
# Windows PowerShell:
# Copy-Item .env.example .env
# =============================================================


# =============================================================
# 1) アプリ基本設定
# =============================================================

# Expressサーバーのポート番号
# docker-compose.yml の ports と合わせて使う
PORT=3000

# 実行モード
# development: 開発用
# production: 本番用
NODE_ENV=development


# =============================================================
# 2) Supabase
# =============================================================
# ExpressサーバーからSupabaseを使うときに必要
# Project Settings → API から取得する

# SupabaseのURL
# 例: https://xxxx.supabase.co
SUPABASE_URL=

# サーバー専用の秘密キー
# Service Role Key は絶対に公開しない
SUPABASE_SERVICE_ROLE_KEY=

# 公開用キー
# 今回のExpressバックエンドだけなら未使用でもOK
SUPABASE_ANON_KEY=


# =============================================================
# 3) LINE Messaging API
# =============================================================
# LINE Webhook をExpressで受けるときに必要
# LINE Developers Console から取得する

# LINEのアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=

# LINEのシークレット
LINE_CHANNEL_SECRET=


# =============================================================
# 4) Vertex AI (Gemini)
# =============================================================
# AI解析を使うときに必要
# Google Cloud Console から取得する

# GCPのプロジェクトID
VERTEX_PROJECT_ID=

# Vertex AIのリージョン
# 例: asia-northeast1
VERTEX_LOCATION=asia-northeast1


# =============================================================
# 5) Google Spreadsheet / GAS連携
# =============================================================
# スプレッドシートID
# GAS経由で使う場合のメモとして保持
# まだ未使用なら空でOK
SPREADSHEET_ID=


# =============================================================
# 6) ngrok
# =============================================================
# ローカル開発中にWebhookを外部公開するときだけ使う
# 使わないなら空でOK
NGROK_AUTHTOKEN=


# =============================================================
# 7) CORS
# =============================================================
# フロントやGASからExpressを呼ぶときに使う想定
# 今後CORS設定を入れるときに利用する
# まだ未使用でも先に置いておくと事故が減る
FRONTEND_URL=http://localhost:3000