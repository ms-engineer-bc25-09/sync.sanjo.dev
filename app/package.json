{
  "name": "sync-sanjo-app",
  "version": "1.0.0",
  "private": true,
  "description": "Sync Sanjo backend with Express and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --legacy-watch --watch src --ext ts,json --exec tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
